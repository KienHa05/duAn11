# Copy toàn bộ đoạn này và paste vào Terminal rồi Enter

@"
# Dependencies - rất nặng, Cursor không cần index
node_modules/
vendor/

# Cache và build files
storage/
bootstrap/cache/
public/build/
dist/

# Logs và tạm thời
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (bảo mật)
.env
.env.*
!.env.example

# Optional: ignore tests nếu không muốn AI đọc nhiều
# tests/

# IDE files
.vscode/
.cursor/
.idea/
*.swp
*.swo
.DS_Store
"@ > .cursorignore
